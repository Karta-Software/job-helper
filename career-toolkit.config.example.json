{
  "graph": {
    "adapter": "obsidian",
    "root": "C:/Users/example/Documents/Obsidian/Career",
    "entrypoint": "Index.md"
  },
  "workspace": {
    "root": ".career-toolkit"
  },
  "privacy": {
    "redactPersonalContactInfo": true,
    "neverCommitGraph": true
  },
  "profile": {
    "targetRoles": ["Example Target Role"],
    "locationPreference": "remote-or-local",
    "dealbreakers": [],
    "searchProfilePath": ".career-toolkit/jobs/search-profile.json"
  },
  "jobs": {
    "sources": ["manual", "csv", "pasted-posting"],
    "autoApply": false,
    "preferEmployerLinks": true,
    "moveBrokenOrConfusingLinksDown": true,
    "requireFullTimeByDefault": true,
    "defaultLinkReviewStatus": "unknown"
  },
  "resumes": {
    "defaultConstraintsPath": ".career-toolkit/resumes/resume-constraints.json",
    "keepTargetingNotesOutsideResume": true,
    "defaultMaxPages": 1
  }
}
