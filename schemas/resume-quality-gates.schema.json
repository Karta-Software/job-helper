{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ResumeQualityGates",
  "type": "object",
  "required": ["id", "version", "gates", "agentRouting"],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "gates": {
      "type": "object",
      "properties": {
        "pages": { "$ref": "#/$defs/rangeGate" },
        "words": { "$ref": "#/$defs/rangeGate" },
        "charactersIncludingSpaces": { "$ref": "#/$defs/rangeGate" },
        "renderedTextLines": { "$ref": "#/$defs/rangeGate" },
        "pageUtilizationPercent": { "$ref": "#/$defs/rangeGate" },
        "visualBottomGapPercent": { "$ref": "#/$defs/rangeGate" },
        "visualBottomToReferenceMarginRatio": { "$ref": "#/$defs/rangeGate" },
        "bulletCharacters": { "$ref": "#/$defs/rangeGate" },
        "achievementBullets": { "$ref": "#/$defs/rangeGate" },
        "requiredSections": {
          "type": "object",
          "required": ["enabled", "sections", "severity", "reworkAgent"],
          "properties": {
            "enabled": { "type": "boolean" },
            "sections": {
              "type": "array",
              "items": { "type": "string" }
            },
            "severity": { "$ref": "#/$defs/severity" },
            "reworkAgent": { "type": "string" }
          }
        },
        "keywordMatch": {
          "type": "object",
          "required": ["enabled", "minimumPercent", "severity", "reworkAgent"],
          "properties": {
            "enabled": { "type": "boolean" },
            "minimumPercent": { "type": "number" },
            "requiredKeywords": {
              "type": "array",
              "items": { "type": "string" }
            },
            "ignoredKeywords": {
              "type": "array",
              "items": { "type": "string" }
            },
            "severity": { "$ref": "#/$defs/severity" },
            "reworkAgent": { "type": "string" }
          }
        },
        "agentPlatformEvidenceDepth": { "$ref": "#/$defs/agentPlatformEvidenceDepthGate" },
        "semanticBulletReview": { "$ref": "#/$defs/semanticBulletReviewGate" },
        "metricSignals": {
          "type": "object",
          "required": ["enabled", "minimumCount", "patterns", "severity", "reworkAgent"],
          "properties": {
            "enabled": { "type": "boolean" },
            "minimumCount": { "type": "integer" },
            "patterns": {
              "type": "array",
              "items": { "type": "string" }
            },
            "severity": { "$ref": "#/$defs/severity" },
            "reworkAgent": { "type": "string" }
          }
        },
        "numericConsistency": { "$ref": "#/$defs/numericConsistencyGate" },
        "privateLeak": {
          "type": "object",
          "required": ["enabled", "patterns", "severity", "reworkAgent"],
          "properties": {
            "enabled": { "type": "boolean" },
            "patterns": {
              "type": "array",
              "items": { "type": "string" }
            },
            "severity": { "$ref": "#/$defs/severity" },
            "reworkAgent": { "type": "string" }
          }
        },
        "approvedSkillClaims": {
          "type": "object",
          "required": ["enabled", "claimTerms", "approvedTerms", "severity", "reworkAgent"],
          "properties": {
            "enabled": { "type": "boolean" },
            "claimTerms": {
              "type": "array",
              "items": { "type": "string" }
            },
            "approvedTerms": {
              "type": "array",
              "items": { "type": "string" }
            },
            "severity": { "$ref": "#/$defs/severity" },
            "reworkAgent": { "type": "string" }
          }
        },
        "educationWording": {
          "type": "object",
          "required": ["enabled", "severity", "reworkAgent"],
          "properties": {
            "enabled": { "type": "boolean" },
            "requiredTerms": {
              "type": "array",
              "items": { "type": "string" }
            },
            "forbiddenTerms": {
              "type": "array",
              "items": { "type": "string" }
            },
            "severity": { "$ref": "#/$defs/severity" },
            "reworkAgent": { "type": "string" }
          }
        },
        "unsupportedTerms": {
          "type": "object",
          "required": ["enabled", "terms", "severity", "reworkAgent"],
          "properties": {
            "enabled": { "type": "boolean" },
            "terms": {
              "type": "array",
              "items": { "type": "string" }
            },
            "allowedContexts": {
              "type": "array",
              "items": { "type": "string" }
            },
            "severity": { "$ref": "#/$defs/severity" },
            "reworkAgent": { "type": "string" }
          }
        },
        "targetBranding": {
          "type": "object",
          "required": ["enabled", "targetNames", "severity", "reworkAgent"],
          "properties": {
            "enabled": { "type": "boolean" },
            "targetNames": {
              "type": "array",
              "items": { "type": "string" }
            },
            "checkResumeText": { "type": "boolean" },
            "checkArtifactNames": { "type": "boolean" },
            "severity": { "$ref": "#/$defs/severity" },
            "reworkAgent": { "type": "string" }
          }
        },
        "reviewerPrinciples": {
          "type": "object",
          "required": ["enabled", "severity", "reworkAgent"],
          "properties": {
            "enabled": { "type": "boolean" },
            "severity": { "$ref": "#/$defs/severity" },
            "reworkAgent": { "type": "string" },
            "leadershipNearTop": { "$ref": "#/$defs/topTextPrincipleGate" },
            "ledTeamWording": {
              "type": "object",
              "required": ["enabled", "requiredPatterns"],
              "properties": {
                "enabled": { "type": "boolean" },
                "requiredPatterns": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "severity": { "$ref": "#/$defs/severity" },
                "reworkAgent": { "type": "string" }
              }
            },
            "topHalfCarriesReview": { "$ref": "#/$defs/topTextPrincipleGate" },
            "consistentEmphasis": {
              "type": "object",
              "required": ["enabled", "mode"],
              "properties": {
                "enabled": { "type": "boolean" },
                "mode": { "enum": ["no-emphasis-in-bullets"] },
                "severity": { "$ref": "#/$defs/severity" },
                "reworkAgent": { "type": "string" }
              }
            },
            "teamLedWorkNotFlattened": {
              "type": "object",
              "required": ["enabled", "minimumLeadershipBullets", "leadershipTerms"],
              "properties": {
                "enabled": { "type": "boolean" },
                "minimumLeadershipBullets": { "type": "integer" },
                "leadershipTerms": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "severity": { "$ref": "#/$defs/severity" },
                "reworkAgent": { "type": "string" }
              }
            },
            "founderSignalBalance": { "$ref": "#/$defs/founderSignalGate" }
          }
        }
      }
    },
    "agentRouting": {
      "type": "object",
      "required": ["maxIterations", "defaultReworkSkill", "notifyAgents"],
      "properties": {
        "maxIterations": { "type": "integer" },
        "defaultReworkSkill": { "type": "string" },
        "notifyAgents": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "severity": {
      "enum": ["error", "warning"]
    },
    "rangeGate": {
      "type": "object",
      "required": ["enabled", "severity", "reworkAgent"],
      "properties": {
        "enabled": { "type": "boolean" },
        "minimum": { "type": "number" },
        "idealLow": { "type": "number" },
        "idealHigh": { "type": "number" },
        "maximum": { "type": "number" },
        "severity": { "$ref": "#/$defs/severity" },
        "reworkAgent": { "type": "string" }
      }
    },
    "topTextPrincipleGate": {
      "type": "object",
      "required": ["enabled", "requiredTerms", "maxTextPercent"],
      "properties": {
        "enabled": { "type": "boolean" },
        "requiredTerms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "maxTextPercent": { "type": "number" },
        "severity": { "$ref": "#/$defs/severity" },
        "reworkAgent": { "type": "string" }
      }
    },
    "founderSignalGate": {
      "type": "object",
      "required": [
        "enabled",
        "topTextPercent",
        "proofTextPercent",
        "targetRoleTerms",
        "founderTerms",
        "proofGroups",
        "minimumProofGroups",
        "collaborationTerms",
        "minimumCollaborationMatches",
        "technicalTerms",
        "minimumTechnicalMatches",
        "forbiddenTerms",
        "forbiddenAttributionPatterns"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "topTextPercent": { "type": "number", "minimum": 1, "maximum": 100 },
        "proofTextPercent": { "type": "number", "minimum": 1, "maximum": 100 },
        "targetRoleTerms": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "founderTerms": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "proofGroups": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/founderProofGroup" }
        },
        "minimumProofGroups": { "type": "integer", "minimum": 1 },
        "collaborationTerms": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "minimumCollaborationMatches": { "type": "integer", "minimum": 1 },
        "technicalTerms": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "minimumTechnicalMatches": { "type": "integer", "minimum": 1 },
        "forbiddenTerms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbiddenAttributionPatterns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "severity": { "$ref": "#/$defs/severity" },
        "reworkAgent": { "type": "string" }
      }
    },
    "founderProofGroup": {
      "type": "object",
      "required": ["id", "terms"],
      "properties": {
        "id": { "type": "string" },
        "terms": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "agentPlatformEvidenceDepthGate": {
      "type": "object",
      "required": [
        "enabled",
        "minimumDimensions",
        "dimensions",
        "usageOnlyTerms",
        "platformBuildTerms",
        "minimumPlatformBuildMatches",
        "topTextPercent",
        "architectureTerms",
        "minimumArchitectureMatchesInBullet",
        "outcomePatterns",
        "severity",
        "reworkAgent"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "minimumDimensions": { "type": "integer", "minimum": 1 },
        "dimensions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/agentPlatformEvidenceDimension" }
        },
        "supportedStatuses": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "usageOnlyTerms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "platformBuildTerms": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "minimumPlatformBuildMatches": { "type": "integer", "minimum": 1 },
        "topTextPercent": { "type": "number", "minimum": 1, "maximum": 100 },
        "architectureTerms": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "minimumArchitectureMatchesInBullet": { "type": "integer", "minimum": 1 },
        "outcomePatterns": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "minimumOutcomeMatches": { "type": "integer", "minimum": 1 },
        "severity": { "$ref": "#/$defs/severity" },
        "reworkAgent": { "type": "string" }
      }
    },
    "agentPlatformEvidenceDimension": {
      "type": "object",
      "required": ["id", "terms", "evidenceStatus", "evidenceRefs"],
      "properties": {
        "id": { "type": "string" },
        "terms": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "minimumTermMatches": { "type": "integer", "minimum": 1 },
        "evidenceStatus": {
          "enum": ["supported", "adjacent", "project-only", "do-not-claim"]
        },
        "evidenceRefs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "semanticBulletReviewGate": {
      "type": "object",
      "required": [
        "enabled",
        "conceptGroups",
        "minimumSharedConcepts",
        "postingPhrases",
        "minimumPostingPhraseMatches",
        "proofPatterns",
        "manualReviewStatus",
        "severity",
        "reworkAgent"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "conceptGroups": {
          "type": "array",
          "items": { "$ref": "#/$defs/semanticConceptGroup" }
        },
        "minimumSharedConcepts": { "type": "integer", "minimum": 1 },
        "postingPhrases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "minimumPostingPhraseMatches": { "type": "integer", "minimum": 1 },
        "proofPatterns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "manualReviewStatus": { "enum": ["not-reviewed", "pass", "fail"] },
        "manualReviewNotes": { "type": "string" },
        "severity": { "$ref": "#/$defs/severity" },
        "reworkAgent": { "type": "string" }
      }
    },
    "semanticConceptGroup": {
      "type": "object",
      "required": ["id", "terms"],
      "properties": {
        "id": { "type": "string" },
        "terms": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "numericConsistencyGate": {
      "type": "object",
      "required": ["enabled", "severity", "reworkAgent"],
      "properties": {
        "enabled": { "type": "boolean" },
        "claims": {
          "type": "array",
          "items": { "$ref": "#/$defs/numericClaim" }
        },
        "relationships": {
          "type": "array",
          "items": { "$ref": "#/$defs/numericRelationship" }
        },
        "forbiddenPatterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/numericForbiddenPattern" }
        },
        "severity": { "$ref": "#/$defs/severity" },
        "reworkAgent": { "type": "string" }
      }
    },
    "numericClaim": {
      "type": "object",
      "required": ["id", "pattern"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "pattern": { "type": "string" },
        "flags": { "type": "string" },
        "valueGroup": { "type": "integer" },
        "required": { "type": "boolean" },
        "unit": { "type": "string" }
      }
    },
    "numericRelationship": {
      "type": "object",
      "required": ["operator"],
      "properties": {
        "id": { "type": "string" },
        "left": { "type": "string" },
        "operator": { "enum": [">", ">=", "<", "<=", "=", "==", "sumEquals"] },
        "right": {
          "oneOf": [
            { "type": "string" },
            { "type": "number" }
          ]
        },
        "value": {
          "oneOf": [
            { "type": "string" },
            { "type": "number" }
          ]
        },
        "total": {
          "oneOf": [
            { "type": "string" },
            { "type": "number" }
          ]
        },
        "addends": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tolerance": { "type": "number" },
        "message": { "type": "string" }
      }
    },
    "numericForbiddenPattern": {
      "type": "object",
      "required": ["pattern"],
      "properties": {
        "id": { "type": "string" },
        "pattern": { "type": "string" },
        "flags": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
