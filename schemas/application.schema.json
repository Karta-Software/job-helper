{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Application",
  "type": "object",
  "required": ["id", "jobPostingId", "status", "nextAction"],
  "properties": {
    "id": { "type": "string" },
    "jobPostingId": { "type": "string" },
    "status": {
      "enum": ["applied", "recruiter-screen", "technical-screen", "onsite-final", "offer", "rejected", "passed", "archived"]
    },
    "opportunityId": { "type": "string" },
    "fitScore": { "type": "number" },
    "fitBucket": { "enum": ["strong", "possible", "stretch", "blocked", "unknown"] },
    "nextAction": { "type": "string" },
    "followUpDate": { "type": "string", "format": "date" },
    "resumeVersionId": { "type": "string" },
    "linkReviewStatus": {
      "enum": [
        "live",
        "broken",
        "unavailable",
        "expired",
        "confusing",
        "generic-search",
        "redirected",
        "login-required",
        "paywalled",
        "duplicate",
        "unknown"
      ]
    },
    "notes": { "type": "string" }
  }
}
