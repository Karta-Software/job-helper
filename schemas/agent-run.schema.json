{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentRun",
  "type": "object",
  "required": ["id", "agent", "startedAt", "status"],
  "properties": {
    "id": { "type": "string" },
    "agent": { "type": "string" },
    "startedAt": { "type": "string", "format": "date-time" },
    "endedAt": { "type": "string", "format": "date-time" },
    "status": { "enum": ["running", "complete", "failed"] },
    "inputs": { "type": "object" },
    "outputs": { "type": "object" }
  }
}
